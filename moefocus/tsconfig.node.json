{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./out",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "lib": ["ESNext"],
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "electron/**/*.ts",
    "electron.vite.config.ts"
  ]
}
